import os
import warnings
import numpy as np
import pandas as pd
import xgboost as xgb
from sklearn.metrics import mean_squared_error

warnings.filterwarnings('ignore')

def load_data():
    """Load engineered features and raw prices."""
    features = pd.read_csv('data/processed/model_features.csv', index_col=0, parse_dates=True)
    prices = pd.read_csv('data/raw/historical_prices.csv', index_col=0, parse_dates=True)
    return features, prices

def create_targets(prices, horizon=21):
    """
    Calculate forward returns as the target variable.
    horizon=21 represents approximately one trading month.
    """
    targets = (prices.shift(-horizon) / prices) - 1
    return targets.dropna()

def train_and_predict(features, targets):
    """
    Train an XGBoost regressor for each sector.
    Returns the View vector (Q) and the Uncertainty matrix diagonal (Omega).
    """
    common_idx = features.index.intersection(targets.index)
    X = features.loc[common_idx]
    y = targets.loc[common_idx]
    
    # 80% train, 20% test (no random shuffling because we are are working with time series)
    split_idx = int(len(X) * 0.8)
    X_train, X_test = X.iloc[:split_idx], X.iloc[split_idx:]
    y_train, y_test = y.iloc[:split_idx], y.iloc[split_idx:]
    
    predictions = {}
    uncertainty = {}
    
    for sector in y.columns:
        if sector == 'SPY':
            continue  # We only need views on the individual sectors
            
        model = xgb.XGBRegressor(
            n_estimators=100,
            learning_rate=0.05,
            max_depth=4,
            random_state=42,
            objective='reg:squarederror'
        )
        
        model.fit(X_train, y_train[sector])
        preds = model.predict(X_test)
        
        # The View (Q) is the model's most recent forward prediction
        predictions[sector] = preds[-1]
        
        # The Uncertainty (Omega) is the historical Mean Squared Error of the model
        mse = mean_squared_error(y_test[sector], preds)
        uncertainty[sector] = mse
        
    return pd.Series(predictions), pd.Series(uncertainty)

if __name__ == "__main__":
    features, prices = load_data()
    
    # Target: 21 trading days (1 month) forward return
    targets = create_targets(prices, horizon=21)
    
    Q, Omega_diag = train_and_predict(features, targets)
    
    # Save the output arrays for the Black-Litterman optimizer
    os.makedirs('data/processed', exist_ok=True)
    Q.to_csv('data/processed/views_q.csv', header=['Expected_Return'])
    Omega_diag.to_csv('data/processed/views_omega.csv', header=['Uncertainty_MSE'])
    
    print("SUCCESS: XGBoost models trained. Views (Q) and Uncertainty (Omega) extracted.")